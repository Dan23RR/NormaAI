# ===========================================================================
# NormaAI - Environment Configuration
# ===========================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED].
# All other variables have sensible defaults for local development.
# ===========================================================================

# ─── Application ──────────────────────────────────────────────────
# [REQUIRED] Application secret key (min 64 chars). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
APP_SECRET_KEY=

# Environment: development | staging | production
APP_ENV=development

# Comma-separated CORS origins
CORS_ORIGINS=http://localhost:3000

# ─── LLM Provider ────────────────────────────────────────────────
# Choose provider: gemini | anthropic | openrouter
LLM_PROVIDER=gemini

# [REQUIRED - pick one] Google Gemini API key
GOOGLE_API_KEY=

# Anthropic API key (required only if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# OpenRouter (OpenAI-compatible gateway, https://openrouter.ai/keys).
# Useful for real-LLM testing on free-tier models and as a BYO-key path.
# Requires the extra:  poetry install -E openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL_ANALYSIS=nvidia/nemotron-3-super-120b-a12b:free

# LLM model names (defaults shown)
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── Database (PostgreSQL) ────────────────────────────────────────
# [REQUIRED for docker compose] Postgres superuser password for the
# bundled postgres service (compose refuses to start without it).
POSTGRES_PASSWORD=

# PostgreSQL async connection string
DATABASE_URL=postgresql+asyncpg://normaai:normaai_dev_pw@localhost:5432/normaai

# Sync variant (for Alembic migrations)
DATABASE_URL_SYNC=postgresql://normaai:normaai_dev_pw@localhost:5432/normaai

# ─── Vector Database (Qdrant) ────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Embedding model - multilingual by default (IT+EN legal corpus & queries).
# Switching models requires re-seeding the corpus (see ADR-006).
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
EMBEDDING_DIMENSION=768
EMBEDDING_BATCH_SIZE=32

# ─── Cache & Token Store (Redis) ─────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# Cache TTL in seconds (default: 1 hour)
CACHE_TTL_SECONDS=3600

# ─── Authentication (JWT RS256) ──────────────────────────────────
# Path to RSA key files. Generate with:
#   openssl genrsa -out jwt_private.pem 2048
#   openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
JWT_PRIVATE_KEY_PATH=jwt_private.pem
JWT_PUBLIC_KEY_PATH=jwt_public.pem

# Token TTL (seconds)
ACCESS_TOKEN_TTL=900        # 15 minutes
REFRESH_TOKEN_TTL=604800    # 7 days

# ─── EUR-Lex Crawler ─────────────────────────────────────────────
EURLEX_SPARQL_ENDPOINT=https://publications.europa.eu/webapi/rdf/sparql

# Background refresh loop ("updated nightly"). OFF by default; set true on a
# SINGLE process/replica that should own the periodic EUR-Lex/Normattiva sync.
ACQUISITION_SCHEDULER_ENABLED=false

# ─── Normattiva (Italian Legislation) ────────────────────────────
NORMATTIVA_API_BASE_URL=https://www.normattiva.it/opendata

# Data source for seeding: eurlex | normattiva | both
DATA_SOURCE=eurlex

# ─── Observability (optional) ────────────────────────────────────
# OpenTelemetry OTLP endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Sentry DSN (optional - error tracking)
SENTRY_DSN=

# [REQUIRED for docker compose] Grafana admin password (no default -
# compose refuses to start the grafana service without it).
GRAFANA_PASSWORD=

# Bearer token protecting /api/v1/metrics/prometheus (scrape auth).
PROMETHEUS_BEARER_TOKEN=

# ─── Local LLM Router (optional) ─────────────────────────────────
# Enable the local LLM for fast framework classification
LOCAL_LLM_ENABLED=false
LOCAL_LLM_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0
LOCAL_LLM_MAX_TOKENS=256

# ─── Rate Limiting ───────────────────────────────────────────────
# Default global rate limit
RATE_LIMIT_DEFAULT=100/minute

# ─── Development ─────────────────────────────────────────────────
# Disable rate limiting in dev
# RATE_LIMIT_ENABLED=false

# Enable debug logging
# LOG_LEVEL=DEBUG

# ─── Public URL (for tracking links in emails) ───────────────────
# Used by email_client to build absolute URLs (Codex download, unsubscribe)
NORMAAI_PUBLIC_URL=https://normaai.org

# ─── Resend (transactional email outbound) ───────────────────────
# Free tier: 3000 email/month, 100/day. DKIM auto-configured per domain.
# Get key at: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=info@normaai.org
RESEND_FROM_NAME=NormaAI
RESEND_REPLY_TO=info@normaai.org

# Resend webhook signing secret (for open/click tracking)
RESEND_WEBHOOK_SECRET=
