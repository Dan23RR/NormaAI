zi2m4eub

# ─── Marketing drafts (prospect PII - NEVER commit) ────────────
# Personalized cold drafts + ICP pending lists contain prospect personal
# data. They were assumed ignored but weren't - a `git add -A` would have
# staged them. Keep the whole drafts/ subtree out of git.
marketing/drafts/

# ─── Attic (historical artifacts moved out of the root) ────────
_attic/

# ─── Claude / AI assistant ─────────────────────────────────────
# Subagents (.claude/agents/) and slash commands (.claude/commands/)
# ARE committed (versioned operations playbook).
# Keep personal/local settings out:
.claude/settings.local.json
.claude/cache/
.claude/logs/

