# The dependency tree has pre-existing peer conflicts (vite 7 + vitest 4 +
# plugin-react resolve cleanly at runtime but npm's strict peer resolver
# rejects recalculated lockfiles - seen on Vercel builds of Dependabot
# branches: "npm install exited with 1" / ERESOLVE).
# legacy-peer-deps makes installs deterministic for npm install, Vercel,
# and Dependabot alike. Revisit when vitest/vite majors stabilize.
legacy-peer-deps=true
