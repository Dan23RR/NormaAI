# ─── NormaAI Validation Framework Configuration ─────────────────
# Copy this file to .env and fill in values for API mode.
# All settings have sensible defaults for local development.

# ─── Backend Connection ──────────────────────────────────────────
NORMAAI_BASE_URL=http://localhost:8000

# ─── Test User Credentials ───────────────────────────────────────
# The runner will auto-register this user if it doesn't exist.
NORMAAI_TEST_EMAIL=validator@normaai.test
NORMAAI_TEST_PASSWORD=NormaAI_Test_2026!
NORMAAI_TEST_NAME=Validation Runner
NORMAAI_TEST_ORG=NormaAI Validation

# ─── Performance ─────────────────────────────────────────────────
NORMAAI_TIMEOUT=120
NORMAAI_MAX_RETRIES=3
NORMAAI_REQUEST_DELAY_MS=500
